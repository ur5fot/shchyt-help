{
  "name": "shchyt",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "test": "npm run test --workspace=shchyt-server && npm run test --workspace=shchyt-client",
    "lint": "eslint 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts'",
    "lint:fix": "eslint 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts' --fix",
    "format": "prettier --write 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts'",
    "install:all": "npm install",
    "init-vector-db": "tsx scripts/init-vector-db.ts",
    "update-law": "tsx scripts/update-laws.ts",
    "eval": "tsx scripts/eval.ts"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
