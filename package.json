{
  "name": "shchyt",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "test": "npm run test --workspace=shchyt-server && npm run test --workspace=shchyt-client",
    "install:all": "npm install"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.2"
  }
}
